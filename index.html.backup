<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI PM Odyssey - From Spreadsheet PM to AI Product Wizard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading-screen">
        <div class="loader-content">
            <div class="loader-icon">🚀</div>
            <div class="loader-text" id="loader-text">Initializing neural pathways...</div>
            <div class="loader-bar"><div class="loader-progress"></div></div>
        </div>
    </div>

    <!-- Particle Canvas -->
    <canvas id="particle-canvas"></canvas>

    <!-- Main App -->
    <div id="app" style="display:none;">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <span class="logo-icon">🧠</span>
                    <span class="logo-text">AI PM Odyssey</span>
                </div>
                <div class="profile-card">
                    <div class="avatar">
                        <img src="https://api.dicebear.com/7.x/bottts/svg?seed=pm-odyssey&backgroundColor=7c3aed" alt="Avatar">
                        <div class="status-dot"></div>
                    </div>
                    <div class="profile-info">
                        <span class="profile-name">AI Apprentice</span>
                        <span class="profile-title">Level 1 PM</span>
                    </div>
                </div>
                <div class="xp-bar-container">
                    <div class="xp-label">
                        <span>XP</span>
                        <span><span id="current-xp">0</span> / <span id="xp-to-next">100</span></span>
                    </div>
                    <div class="xp-bar">
                        <div class="xp-fill" id="xp-fill" style="width:0%"></div>
                    </div>
                </div>
                <div class="streak-display">
                    <span>🔥</span>
                    <span id="streak-count">0</span> day streak
                </div>
            </div>

            <div class="sidebar-nav">
                <a href="#" class="nav-item active" data-section="home">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-label">Mission Control</span>
                </a>
                <a href="#" class="nav-item" data-section="modules">
                    <span class="nav-icon">📚</span>
                    <span class="nav-label">Learning Worlds</span>
                </a>
                <a href="#" class="nav-item" data-section="skills">
                    <span class="nav-icon">⚡</span>
                    <span class="nav-label">Skill Tree</span>
                </a>
                <a href="#" class="nav-item" data-section="playground">
                    <span class="nav-icon">🎮</span>
                    <span class="nav-label">AI Playground</span>
                </a>
                <a href="#" class="nav-item" data-section="achievements">
                    <span class="nav-icon">🏆</span>
                    <span class="nav-label">Achievements</span>
                </a>
                <a href="#" class="nav-item" data-section="leaderboard">
                    <span class="nav-icon">👑</span>
                    <span class="nav-label">Leaderboard</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <div class="daily-challenge">
                    <span class="challenge-label">🎯 Daily Challenge</span>
                    <span class="challenge-text">Complete 1 lesson</span>
                    <div class="challenge-progress">
                        <div class="challenge-fill" style="width:0%"></div>
                    </div>
                </div>
                <div class="ai-news-ticker">
                    <span class="ticker-label">📡 AI News</span>
                    <div class="ticker-text">GPT-5 just dropped. Your move, PM.</div>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main id="main-content">
            <!-- HOME SECTION -->
            <section id="section-home" class="section active">
                <!-- Hero -->
                <div class="hero">
                    <div class="hero-badge">
                        <span>🚀 AI PM Odyssey v1.0</span>
                    </div>
                    <h1 class="hero-title">
                        <span class="gradient-text">From Spreadsheet PM</span>
                        <span class="block">→ <span class="neon-text">AI Product Wizard</span></span>
                    </h1>
                    <p class="hero-subtitle">The gamified universe where Product Managers become AI legends. No fluff. Just dopamine-fueled learning.</p>
                    
                    <!-- Journey Map -->
                    <div class="journey-map">
                        <div class="journey-start">
                            <div class="journey-card confused">
                                <div class="journey-icon">😰</div>
                                <h3>YOU ARE HERE</h3>
                                <div class="journey-details">
                                    <p>Drowning in Jira tickets</p>
                                    <p>37 Slack notifications/min</p>
                                    <p>Roadmap chaos level: MAX</p>
                                    <p>AI knowledge: <span class="meter low">▰▰▰▰▰▰▰▰▰▰ 10%</span></p>
                                </div>
                                <div class="sticker">"Is AI just fancy Excel?"</div>
                            </div>
                        </div>

                        <div class="journey-path">
                            <div class="path-line"></div>
                            <div class="path-nodes">
                                <div class="path-node" data-level="1">Lv.1</div>
                                <div class="path-node" data-level="25">Lv.25</div>
                                <div class="path-node" data-level="50">Lv.50</div>
                                <div class="path-node" data-level="75">Lv.75</div>
                                <div class="path-node" data-level="100">Lv.100</div>
                            </div>
                            <div class="path-progress" id="path-progress"></div>
                            <div class="traveling-icons">
                                <span class="travel-icon" style="top:20%">🚀</span>
                                <span class="travel-icon" style="top:40%">🤖</span>
                                <span class="travel-icon" style="top:60%">⚡</span>
                                <span class="travel-icon" style="top:80%">🧠</span>
                            </div>
                        </div>

                        <div class="journey-end">
                            <div class="journey-card wizard">
                                <div class="journey-icon">🧙‍♂️</div>
                                <h3>YOUR DESTINATION</h3>
                                <div class="journey-details">
                                    <p>Controls AI agents with mind</p>
                                    <p>Fluent in LLM (it's a language now)</p>
                                    <p>Salary: 💰💰💰💰💰</p>
                                    <p>AI mastery: <span class="meter high">▰▰▰▰▰▰▰▰▰▰ 100%</span></p>
                                </div>
                                <div class="sticker">"I am the API now."</div>
                            </div>
                        </div>
                    </div>

                    <!-- CTA Buttons -->
                    <div class="cta-group">
                        <button class="cta-btn primary" onclick="startJourney()">
                            <span>Start My AI Journey</span>
                            <span class="btn-particle">✨</span>
                        </button>
                        <button class="cta-btn secondary" onclick="showNotification('Bold move. Let\'s see where you\'re at.')">
                            <span>I'm Already Dangerous</span>
                        </button>
                        <button class="cta-btn outline" onclick="showNotification('Okay, let\'s keep it simple. No jargon. Just vibes.')">
                            <span>Teach Me Like I'm a PM</span>
                        </button>
                        <button class="cta-btn danger" onclick="deployChaos()">
                            <span>Deploy Chaos</span>
                            <span class="btn-particle">💥</span>
                        </button>
                    </div>

                    <!-- Floating Elements -->
                    <div class="floating-elements">
                        <div class="float-item" style="top:10%;left:5%;animation-delay:0s">🤖</div>
                        <div class="float-item" style="top:20%;right:10%;animation-delay:1s">🚀</div>
                        <div class="float-item" style="top:50%;left:2%;animation-delay:2s">📝</div>
                        <div class="float-item" style="top:70%;right:5%;animation-delay:0.5s">⚡</div>
                        <div class="float-item" style="top:40%;left:8%;animation-delay:1.5s">🧠</div>
                        <div class="float-item" style="top:80%;left:3%;animation-delay:2.5s">💡</div>
                        <div class="float-item" style="top:15%;right:3%;animation-delay:3s">🎯</div>
                        <div class="float-item" style="top:60%;right:8%;animation-delay:1.8s">🔥</div>
                    </div>
                </div>

                <!-- Stats Overview -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon">📚</div>
                        <div class="stat-info">
                            <span class="stat-value" id="lessons-completed">0</span>
                            <span class="stat-label">Lessons Done</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">⭐</div>
                        <div class="stat-info">
                            <span class="stat-value" id="total-xp">0</span>
                            <span class="stat-label">Total XP</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">🏆</div>
                        <div class="stat-info">
                            <span class="stat-value" id="achievements-count">0</span>
                            <span class="stat-label">Achievements</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon">🔥</div>
                        <div class="stat-info">
                            <span class="stat-value" id="streak-display-count">0</span>
                            <span class="stat-label">Day Streak</span>
                        </div>
                    </div>
                </div>

                <!-- Quick Modules Preview -->
                <div class="section-header">
                    <h2>🎯 Continue Your Journey</h2>
                    <button class="view-all" onclick="switchSection('modules')">View All →</button>
                </div>
                <div class="modules-grid" id="modules-preview"></div>
            </section>

            <!-- MODULES SECTION -->
            <section id="section-modules" class="section">
                <div class="section-header">
                    <h2>🌍 Learning Worlds</h2>
                    <div class="filter-group">
                        <button class="filter-btn active" data-filter="all">All</button>
                        <button class="filter-btn" data-filter="beginner">Beginner</button>
                        <button class="filter-btn" data-filter="intermediate">Intermediate</button>
                        <button class="filter-btn" data-filter="advanced">Advanced</button>
                    </div>
                </div>
                <div class="modules-grid full" id="modules-full"></div>
            </section>

            <!-- SKILLS SECTION -->
            <section id="section-skills" class="section">
                <div class="section-header">
                    <h2>⚡ Skill Tree</h2>
                    <span class="section-subtitle">Unlock your AI PM potential</span>
                </div>
                <div class="skill-tree-container">
                    <canvas id="skill-tree-canvas"></canvas>
                    <div class="skill-nodes" id="skill-nodes"></div>
                </div>
            </section>

            <!-- PLAYGROUND SECTION -->
            <section id="section-playground" class="section">
                <div class="section-header">
                    <h2>🎮 AI Playground</h2>
                    <span class="section-subtitle">Experiment. Break things. Learn.</span>
                </div>
                <div class="playground-grid">
                    <div class="playground-card" onclick="openPromptPlayground()">
                        <div class="playground-icon">💬</div>
                        <h3>Prompt Battle Arena</h3>
                        <p>Battle against bad prompts. Make them sing.</p>
                        <span class="playground-tag">Interactive</span>
                    </div>
                    <div class="playground-card" onclick="openQuiz()">
                        <div class="playground-icon">🧪</div>
                        <h3>AI Quiz Generator</h3>
                        <p>Test your knowledge. No pressure. Okay, maybe a little.</p>
                        <span class="playground-tag">Quiz</span>
                    </div>
                    <div class="playground-card" onclick="openArchitectureBuilder()">
                        <div class="playground-icon">🏗️</div>
                        <h3>Architecture Builder</h3>
                        <p>Drag & drop your way to AI system design glory.</p>
                        <span class="playground-tag">Sandbox</span>
                    </div>
                    <div class="playground-card" onclick="openAIChat()">
                        <div class="playground-icon">🤖</div>
                        <h3>AI Mentor Chat</h3>
                        <p>Your personal AI PM sensei. Wiser than your VP Product.</p>
                        <span class="playground-tag">AI</span>
                    </div>
                </div>
            </section>

            <!-- ACHIEVEMENTS SECTION -->
            <section id="section-achievements" class="section">
                <div class="section-header">
                    <h2>🏆 Achievements</h2>
                    <span class="section-subtitle">Bragging rights included</span>
                </div>
                <div class="achievements-grid" id="achievements-grid"></div>
            </section>

            <!-- LEADERBOARD SECTION -->
            <section id="section-leaderboard" class="section">
                <div class="section-header">
                    <h2>👑 Leaderboard</h2>
                    <span class="section-subtitle">Compete with fellow AI PMs</span>
                </div>
                <div class="leaderboard-container" id="leaderboard-container"></div>
            </section>
        </main>

        <!-- AI Mentor Chat -->
        <div id="ai-chat" class="chat-widget collapsed">
            <div class="chat-header" onclick="toggleChat()">
                <div class="chat-avatar">🤖</div>
                <div class="chat-header-info">
                    <span class="chat-name">AI Mentor</span>
                    <span class="chat-status">Online • Ready to teach</span>
                </div>
                <span class="chat-toggle">💬</span>
            </div>
            <div class="chat-body" id="chat-body">
                <div class="chat-messages" id="chat-messages">
                    <div class="message ai">
                        <div class="msg-content">Hey there, future AI PM! 👋 I'm your AI mentor. Ask me anything about AI, product management, or why your last roadmap failed. (Just kidding... mostly.)</div>
                    </div>
                </div>
                <div class="chat-input">
                    <input type="text" id="chat-input" placeholder="Ask me anything..." onkeypress="if(event.key==='Enter')sendMessage()">
                    <button onclick="sendMessage()">➤</button>
                </div>
            </div>
        </div>

        <!-- Notification System -->
        <div id="notification-container"></div>

        <!-- Modal System -->
        <div id="modal-overlay" class="modal-overlay" onclick="closeModal()">
            <div class="modal-content" id="modal-content" onclick="event.stopPropagation()">
                <button class="modal-close" onclick="closeModal()">✕</button>
                <div id="modal-body"></div>
            </div>
        </div>

        <!-- XP Popup -->
        <div id="xp-popup" class="xp-popup"></div>
    </div>

    <script type="module" src="js/main.js"></script>
</body>
</html>
